						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"google.com\",\n    \"company_name\": \"Alphabet Inc.\",\n    \"booking_date\": \"2025-01-01\",\n    \"expiry_date\": \"2026-01-01\",\n    \"total_amount\": 5000.00,\n    \"sales_person_id\": 2,\n    \"branch_id\": 1,\n    \"manual_status\": null,\n    \"last_contacted_at\": \"2025-04-20T10:00:00\",\n    \"next_followup_at\": \"2025-05-01T10:00:00\",\n    \"renewal_date\": null,\n    \"renewed_by\": null,\n    \"remark\": \"Initial purchase\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/domains", "host": ["{{base_url}}"], "path": ["domains"] }
					}
				},
				{
					"name": "Get Domain",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": { "raw": "{{base_url}}/domains/1", "host": ["{{base_url}}"], "path": ["domains", "1"] }
					}
				},
				{
					"name": "Update Domain",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"updated-google.com\",\n    \"company_name\": \"Google LLC\",\n    \"expiry_date\": \"2027-01-01\",\n    \"total_amount\": 6000.00,\n    \"sales_person_id\": 2,\n    \"manual_status\": \"On Hold\",\n    \"last_contacted_at\": \"2025-04-24T09:00:00\",\n    \"next_followup_at\": \"2025-05-10T09:00:00\",\n    \"renewal_date\": \"2025-04-24\",\n    \"renewed_by\": 1,\n    \"remark\": \"Renewed for 2027\",\n    \"override_payment_check\": false\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/domains/1", "host": ["{{base_url}}"], "path": ["domains", "1"] }
					}
				},
				{
					"name": "Update Domain (Force Renewal - Override Payment)",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"expiry_date\": \"2027-06-01\",\n    \"override_payment_check\": true\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/domains/1", "host": ["{{base_url}}"], "path": ["domains", "1"] }
					}
				},
				{
					"name": "Delete Domain",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": { "raw": "{{base_url}}/domains/1", "host": ["{{base_url}}"], "path": ["domains", "1"] }
					}
				},
				{
					"name": "Bulk Update Domains",
					"request": {
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"domain_ids\": [1, 2, 3],\n    \"sales_person_id\": 2,\n    \"manual_status\": \"On Hold\",\n    \"next_followup_at\": \"2025-06-01T00:00:00\",\n    \"remark\": \"Bulk update for Q2 review\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/domains/bulk-update", "host": ["{{base_url}}"], "path": ["domains", "bulk-update"] }
					}
				}
