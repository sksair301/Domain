		"name": "Domain API (v3 - Refactored)",
		"description": "API collection for Domain Management.\n\n### Base URL\n`http://127.0.0.1:8002/api`\n\n### Roles:\n- **Superadmin**: admin@example.com / password\n- **Manager**: manager@example.com / password\n- **Employee**: employee@example.com / password",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"New Account\",\n    \"email\": \"newuser@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"role\": \"employee\",\n    \"branch_id\": 1\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/register", "host": ["{{base_url}}"], "path": ["register"] }
					}
				},
				{
					"name": "Login (Superadmin)",
					"event": [{ "listen": "test", "script": { "exec": ["var jsonData = pm.response.json();", "if (jsonData.access_token) {", "    pm.collectionVariables.set(\"token\", jsonData.access_token);", "}"], "type": "text/javascript" } }],
					"request": {
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"password\"\n}", "options": { "raw": { "language": "json" } } },
						"url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
					}
				},
				{
					"name": "Login (Manager)",
					"event": [{ "listen": "test", "script": { "exec": ["var jsonData = pm.response.json();", "if (jsonData.access_token) {", "    pm.collectionVariables.set(\"token\", jsonData.access_token);", "}"], "type": "text/javascript" } }],
					"request": {
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n    \"email\": \"manager@example.com\",\n    \"password\": \"password\"\n}", "options": { "raw": { "language": "json" } } },
						"url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
					}
				},
				{
					"name": "Login (Employee)",
					"event": [{ "listen": "test", "script": { "exec": ["var jsonData = pm.response.json();", "if (jsonData.access_token) {", "    pm.collectionVariables.set(\"token\", jsonData.access_token);", "}"], "type": "text/javascript" } }],
					"request": {
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n    \"email\": \"employee@example.com\",\n    \"password\": \"password\"\n}", "options": { "raw": { "language": "json" } } },
						"url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] }
					}
				}
			]
		},
